{
  "name": "world-cup-live-pulse",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Fan-first live and replay dashboard for World Cup match pulse, events, market movement, and AI commentary.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc --noEmit",
    "fixtures": "node scripts/validate-fixtures.mjs",
    "preflight": "node scripts/preflight.mjs",
    "security": "node scripts/security-scan.mjs",
    "txline:probe": "node scripts/txline-probe.mjs",
    "demo:video": "node scripts/record-demo-video.mjs",
    "validate": "npm run check && npm run fixtures && npm run preflight && npm run security && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3"
  }
}
